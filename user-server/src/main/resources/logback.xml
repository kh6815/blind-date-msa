<?xml version="1.0" encoding="UTF-8"?>
<!-- 30мҙҲл§ҲлӢӨ м„Өм • нҢҢмқјмқҳ ліҖкІҪмқ„ нҷ•мқён•ңлӢӨ. нҢҢмқјмқҙ ліҖкІҪлҗҳл©ҙ лӢӨмӢң лЎңл”©н•ңлӢӨ -->
<configuration scan="true">
	<statusListener class="ch.qos.logback.core.status.NopStatusListener"/>

	<appender name="Console" class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>%magenta([%d{yyyy-MM-dd HH:mm:ss}]) - %highlight([%level]) - %yellow([%thread])- %blue([%mdc{traceId}]) - %red([%mdc{ipAddress}]) - %green([%logger{36}]) - %msg%n</pattern>
		</encoder>
	</appender>

	<!-- API лЎңк№… -->
	<appender name="LogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<!-- INFO, WARNл§Ң лӮЁкё°кі  ERRORлҠ” м ңмҷё -->
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
			<level>ERROR</level>
			<onMatch>DENY</onMatch>
			<onMismatch>NEUTRAL</onMismatch>
		</filter>
		<file>./logs/blind-date-user-server-api.log</file>
		<encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
			<charset>UTF-8</charset>
			<layout class="com.project.blinddate.user.logger.JsonLogLayout"/>
		</encoder>
		<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<!-- лӮ м§ң + мқёлҚұмҠӨ н•„мҲҳ -->
			<fileNamePattern>./logs/blind-date-user-server-api.%d{yyyy-MM-dd}-%i.gz</fileNamePattern>
			<!-- нҢҢмқј н•ҳлӮҳ мөңлҢҖ 1GB -->
			<maxFileSize>1GB</maxFileSize>
			<!-- 60мқј ліҙкҙҖ -->
			<maxHistory>1</maxHistory>
			<!-- м „мІҙ лЎңк·ё мҙқн•© м ңн•ң (м„ нғқ) -->
			<totalSizeCap>1GB</totalSizeCap>
		</rollingPolicy>
	</appender>

	<!-- error лЎңк№… -->
	<appender name="ErrorLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
		<filter class="ch.qos.logback.classic.filter.LevelFilter">
			<level>ERROR</level>
			<onMatch>ACCEPT</onMatch>
			<onMismatch>DENY</onMismatch>
		</filter>
		<file>./logs/blind-date-user-server-error.log</file>
		<encoder class="ch.qos.logback.core.encoder.LayoutWrappingEncoder">
			<charset>UTF-8</charset>
			<layout class="com.project.blinddate.user.logger.JsonLogLayout"/>
		</encoder>
		<!-- н•ҳлЈЁм—җ н•ңлІҲ м••м¶• нӣ„ ліҙкҙҖ, мөңлҢҖ 30мқј, 1GBк№Ңм§Җ ліҙкҙҖ -->
		<rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
			<!-- лӮ м§ң + мқёлҚұмҠӨ н•„мҲҳ -->
			<fileNamePattern>./logs/blind-date-user-server-error.%d{yyyy-MM-dd}-%i.gz</fileNamePattern>
			<!-- нҢҢмқј н•ҳлӮҳ мөңлҢҖ 1GB -->
			<maxFileSize>1GB</maxFileSize>
			<!-- 1мқј ліҙкҙҖ -->
			<maxHistory>1</maxHistory>
			<!-- м „мІҙ лЎңк·ё мҙқн•© м ңн•ң (м„ нғқ) -->
			<totalSizeCap>1GB</totalSizeCap>
		</rollingPolicy>
	</appender>

	<logger name="org.springframework" level="INFO"/>
	<logger name="jdbc.audit" level="INFO"/>

	<logger name="jdbc.sqlonly" level="INFO" />
	<logger name="org.thymeleaf" level="INFO" />
	<!-- JavaMailSender кҙҖл Ё лЎңк·ё л ҲлІЁ мЎ°м • -->
	<logger name="org.springframework.mail.javamail" level="INFO"/>
	<logger name="javax.mail" level="INFO"/>
	<logger name="com.sun.mail" level="INFO" />
	<logger name="p6spy" level="INFO" additivity="false"/>

	<!-- INFO л ҲлІЁ мқҙмғҒ лӮЁк№Җ - TRACE < DEBUG < INFO < WARN < ERROR < FATAL-->
	<root level="INFO">
		<appender-ref ref="Console"/>
		<appender-ref ref="LogFile"/>
		<appender-ref ref="ErrorLogFile"/>
	</root>
</configuration>
